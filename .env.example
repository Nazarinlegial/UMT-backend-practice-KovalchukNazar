# ─── Server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# Comma-separated list of allowed CORS origins (the Flora frontend dev server).
CORS_ORIGIN=http://localhost:4000,http://localhost:3000

# ─── Database ──────────────────────────────────────────────────────────────
# Local: docker-compose maps the container's 5432 to host 5435.
# Cloud (Render): paste the External Database URL here.
DATABASE_URL="postgresql://flora:flora@localhost:5435/flora?schema=public"

# ─── Image uploads (Cloudinary) ──────────────────────────────────────────────
MAX_FILE_SIZE_MB=6
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=flora

# ─── Auth (admin JWT) ─────────────────────────────────────────────────────────
# Secret used to sign JWTs — use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1d
# Admin account auto-provisioned on startup (login via POST /api/auth/login).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password
